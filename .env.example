# Copier ce fichier en « .env » et ajuster selon votre environnement.
# Ne pas versionner « .env » ni y mettre de vrais mots de passe / clefs secrètes dans le dépôt.

# --- PostgreSQL (obligatoire pour « docker compose » — pas de valeur en clair dans docker-compose.yml) ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Hors Docker / client local : souvent localhost. Sous Compose, docker-compose.yml force POSTGRES_HOST=db pour le backend.
# POSTGRES_HOST=localhost

# --- Stack locale (ports / URL de dev) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000

# --- Django ---
# Ne jamais laisser DEBUG=True en production.
DEBUG=True

# Obligatoire : clef Django — générer via Docker : README (section SECRET_KEY, commande compose --no-deps).
SECRET_KEY=

# En production : listes explicites (domaines et origines réels).
# ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Gemini (génération IA de cours) ---
# Clef API Google AI Studio (https://aistudio.google.com/apikey). Sans clef, l'endpoint /api/formateur/ai/* renvoie 503.
GEMINI_API_KEY=
# Modèle par défaut. Choix possibles : gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro.
GEMINI_MODEL=gemini-2.5-flash-lite
